APP_NAME=video-x-bot
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_WEBHOOK_URL=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

DATABASE_URL=sqlite:///./storage/app.db
REDIS_URL=redis://redis:6379/0

STORAGE_ROOT=./storage
RAW_VIDEO_DIR=./storage/raw
AUDIO_DIR=./storage/audio
TRANSCRIPT_DIR=./storage/transcript
SUBTITLE_DIR=./storage/subtitle
OUTPUT_VIDEO_DIR=./storage/output
LOG_DIR=./storage/logs

ENABLE_BURNED_SUBTITLE=true
ENABLE_AUTO_TRANSLATE_TO_EN=true
ENABLE_SEND_PREVIEW_TO_TELEGRAM=true
REQUIRE_APPROVAL_BEFORE_POST=false
ENABLE_AUTO_POST=true

FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
YTDLP_BIN=yt-dlp
YTDLP_COOKIE_FILE=
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_BROWSER_PROFILE=

MAX_VIDEO_DURATION_SECONDS=300
MAX_VIDEO_FILE_SIZE_MB=200
DOWNLOAD_TIMEOUT_SECONDS=180

DEFAULT_CAPTION_STYLE=public_clean
DEFAULT_OUTPUT_LANGUAGE=en
DEFAULT_PROFILE_CODE=A1
PROFILE_TIMEZONE=UTC
PROFILE_HOURLY_MAP=A1,A1,A1,A1,A2,A2,A2,A2,A3,A3,A3,A3,A4,A4,A4,A4,A1,A1,A1,A2,A2,A3,A4,A4
CAPTION_PROFILES_JSON={"A1":{"language":"en","language_name":"English","style":"public_clean","tone":"clean, safe, concise"},"A2":{"language":"ja","language_name":"Japanese","style":"public_clean","tone":"polite, concise"},"A3":{"language":"ko","language_name":"Korean","style":"public_clean","tone":"natural, concise, social-safe"},"A4":{"language":"zh","language_name":"Chinese","style":"public_clean","tone":"clear, concise, public-safe"}}
